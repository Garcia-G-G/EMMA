# Copy to `.env` and fill in. See linked dashboards for each key.

# OpenAI key — OPTIONAL now (CLIENT-INSTALL Phase 2B). A managed client daemon
# needs NO key: it pairs at theemmafamily.com/pair on first run and calls OpenAI
# through the Emma proxy with a device token (set EMMA_REQUIRE_PAIRING=1). Only a
# dev/BYOK daemon fills this in. https://platform.openai.com/api-keys
OPENAI_API_KEY=

# https://elevenlabs.io/app/settings/api-keys + voice library for IDs
# (DEPRECATED after Prompt 13 Realtime migration, but still required by
# settings.py validation and the health-check tool.)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_ES=
ELEVENLABS_VOICE_ID_EN=

# ---- Realtime API (Prompt 13) -------------------------------------------
# Audio-to-audio session model and voice. The Realtime API replaces the
# old STT -> LLM -> TTS pipeline with a single WebSocket session.
# REALTIME_MODEL=gpt-realtime-2
# REALTIME_VOICE=coral
# SESSION_MAX_S=120
#
# Input transcription model + how the hot-word bias is rendered.
# whisper-1 (default) takes a free-text prompt; its 2026 successor
# gpt-realtime-whisper wants a "Keywords: a, b, c" list (set BIAS_MODE=keywords).
# Docs: https://developers.openai.com/api/docs/guides/realtime-transcription
# REALTIME_TRANSCRIPTION_MODEL=whisper-1
# REALTIME_BIAS_MODE=prompt          # prompt | keywords

# Wake word. Shipped engine: sherpa-onnx KeywordSpotter (always-on offline
# KWS on a fixed keyword list: "emma", "oye emma", "hey emma", …). No
# training, no keys. The installer downloads the model to ~/.emma/sherpa-kws;
# for a manual/dev run, fetch it there and point SHERPA_KWS_MODEL_PATH at it
# (default already matches the installer's path). Per-phrase thresholds live
# in core/wake_sherpa.py:WAKE_PHRASES.
WAKE_WORD_ENGINE=sherpa
# SHERPA_KWS_MODEL_PATH=~/.emma/sherpa-kws/sherpa-onnx-kws-zipformer-gigaspeech-3.3M-2024-01-01
#
# Alternative engines:
#   openwakeword — set WAKE_WORD_ENGINE=openwakeword and point WAKE_WORD_PATH
#     at a trained .onnx (or a built-in name: hey_jarvis, alexa, hey_mycroft,
#     hey_rhasspy). WAKE_WORD_NAME must match the keyword label; tune
#     WAKE_WORD_THRESHOLD (0.4 sensitive … 0.6-0.7 strict).
#   pvporcupine  — needs a .ppn + PICOVOICE_ACCESS_KEY.
#   vosk         — legacy, Linux/Intel only (no macOS arm64 wheel; `.[vosk]`).
WAKE_WORD_PATH=hey_jarvis
WAKE_WORD_NAME=hey_jarvis
WAKE_WORD_THRESHOLD=0.5

# Optional integrations
YOUTUBE_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Web search - set one (Brave preferred). https://api.search.brave.com/ or https://tavily.com/
BRAVE_API_KEY=
TAVILY_API_KEY=

# Optional: postgresql://user:pass@host:5432/db  (falls back to SQLite)
POSTGRES_DSN=

LOG_LEVEL=INFO

# ---- DEPRECATED (kept for env-file compat, no longer read) ----
# STT_MODEL=gpt-4o-mini-transcribe
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5
# ELEVENLABS_LATENCY_MODE=1
# ELEVENLABS_OUTPUT_FORMAT=pcm_16000
# TTS_FIRST_CHUNK_MIN_CHARS=120
# BARGE_IN_ENABLED=true
# BARGE_IN_BLANKING_MS=350
# BARGE_IN_RMS=1200.0
# BARGE_IN_FRAMES=6
# WHISPER_PROMPT=
# STRICT_LANGUAGE_POLICY=true

# ---- Native coding sub-agent (Prompt 23) --------------------------------
# Emma's "delegate_to_codex" runs a Responses-API tool-calling loop INSIDE
# Emma (no external `codex` CLI, no Gatekeeper, no npm). Reuses
# OPENAI_API_KEY above. Model card + pricing:
# https://developers.openai.com/api/docs/models/gpt-5.3-codex
# Alternatives: gpt-5-codex ($1.25/$10, cheaper), gpt-5.5 ($5/$30, more reasoning).
# CODING_AGENT_MODEL=gpt-5.3-codex
# CODING_AGENT_MAX_ITERS=30           # tool-call loop hard cap
# CODING_AGENT_MAX_COST_USD=2.0       # soft cap (asks to confirm); hard kill at 2x
# CODING_AGENT_TIMEOUT_S=1800         # 30-min wall clock
# CODING_AGENT_REASONING=medium       # low | medium | high | xhigh

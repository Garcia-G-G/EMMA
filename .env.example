# Copy to `.env` and fill in. See linked dashboards for each key.

# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Speech-to-text model. Default = gpt-4o-mini-transcribe (much more accurate
# than whisper-1 on Spanish + slang). Set to gpt-4o-transcribe for top quality
# (slower/$$$) or whisper-1 to fall back to the legacy verbose_json language-
# detection path.
# STT_MODEL=gpt-4o-mini-transcribe

# https://elevenlabs.io/app/settings/api-keys + voice library for IDs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_ES=
ELEVENLABS_VOICE_ID_EN=

# ElevenLabs voice tuning. Defaults give natural prosody at ~250 ms time-to-first-byte.
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5     # try eleven_turbo_v2_5 for more expressive but slower
# ELEVENLABS_LATENCY_MODE=1                  # 0 = best prosody, 4 = lowest latency
# ELEVENLABS_OUTPUT_FORMAT=pcm_16000         # do not change unless you also change core.audio.SAMPLE_RATE
# TTS_FIRST_CHUNK_MIN_CHARS=120              # raise for more natural opening sentences

# Barge-in: interrupt Emma by speaking over her. Set to false to revert
# to strict half-duplex (no mic during playback).
# BARGE_IN_ENABLED=true
# BARGE_IN_BLANKING_MS=350    # ignore mic for the first N ms of TTS (echo-suppression heuristic)
# BARGE_IN_RMS=1200.0         # RMS threshold per 32 ms frame; raise on false triggers, lower on misses
# BARGE_IN_FRAMES=6           # consecutive above-threshold frames required (~192 ms of speech)

# Wake word (openWakeWord). The .onnx model is trained per-user via the
# Colab linked in README.md - see "Wake word" section. WAKE_WORD_NAME
# must match the keyword label used during training (lowercase, underscores).
WAKE_WORD_PATH=/Users/go/Documents/EMMA/.venv/lib/python3.12/site-packages/openwakeword/resources/models/hey_mycroft_v0.1.onnx
WAKE_WORD_NAME=hey_mycroft_v0.1
WAKE_WORD_THRESHOLD=0.5

# Optional integrations
YOUTUBE_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Web search - set one (Brave preferred). https://api.search.brave.com/ or https://tavily.com/
BRAVE_API_KEY=
TAVILY_API_KEY=

# Optional: postgresql://user:pass@host:5432/db  (falls back to SQLite)
POSTGRES_DSN=

# Bilingual stability + STT bias (phase 10).
# WHISPER_PROMPT: list of proper nouns, brands, and slang you actually use,
# comma-separated. Increases Whisper recognition accuracy for these terms.
# Do NOT put filler - only words Whisper might mis-transcribe. Max 800 chars.
# Example:
# WHISPER_PROMPT=Garcia, Monterrey, Hetzner, Cowork, Anthropic, Claude, ElevenLabs, Spotify, Nill Ojeda, ándale, ahorita, ¿qué onda?
WHISPER_PROMPT=

# STRICT_LANGUAGE_POLICY: when true (default) Emma never code-switches inside
# a response unless the user explicitly asks for translation, definition, or
# cross-lingual phrasing. Set false to revert to the older permissive guidance.
STRICT_LANGUAGE_POLICY=true

LOG_LEVEL=INFO

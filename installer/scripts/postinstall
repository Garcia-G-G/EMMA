#!/bin/bash
# Runs as root after the pkg drops Emma.app into /Applications (Prompt 29, Part B2).
# Installs the per-user LaunchAgent and triggers the first-run wizard. Everything
# user-owned lands under the console user's ~/Library — never elsewhere.
set -u

APP="/Applications/Emma.app"
EXE="$APP/Contents/MacOS/Emma"

# Resolve the actual logged-in (console) user, not root.
CONSOLE_USER="$(stat -f '%Su' /dev/console)"
[ -z "$CONSOLE_USER" ] || [ "$CONSOLE_USER" = "root" ] && CONSOLE_USER="${USER:-}"
USER_HOME="$(dscl . -read "/Users/$CONSOLE_USER" NFSHomeDirectory 2>/dev/null | awk '{print $2}')"
[ -z "$USER_HOME" ] && USER_HOME="/Users/$CONSOLE_USER"
UID_NUM="$(id -u "$CONSOLE_USER" 2>/dev/null)"

LA_DIR="$USER_HOME/Library/LaunchAgents"
PLIST="$LA_DIR/com.garcia.emma.plist"
mkdir -p "$LA_DIR" "$USER_HOME/Library/Logs/Emma" "$USER_HOME/Library/Application Support/Emma"

cat > "$PLIST" <<PLISTEOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.garcia.emma</string>
  <key>ProgramArguments</key><array><string>$EXE</string></array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><dict><key>SuccessfulExit</key><false/><key>Crashed</key><true/></dict>
  <key>ThrottleInterval</key><integer>10</integer>
  <key>StandardOutPath</key><string>$USER_HOME/Library/Logs/Emma/stdout.log</string>
  <key>StandardErrorPath</key><string>$USER_HOME/Library/Logs/Emma/stderr.log</string>
  <key>ProcessType</key><string>Interactive</string>
</dict></plist>
PLISTEOF

chown -R "$CONSOLE_USER" "$LA_DIR" "$USER_HOME/Library/Logs/Emma" "$USER_HOME/Library/Application Support/Emma"

# (Re)load the agent as the console user.
launchctl bootout "gui/$UID_NUM/com.garcia.emma" 2>/dev/null || true
sudo -u "$CONSOLE_USER" launchctl bootstrap "gui/$UID_NUM" "$PLIST" 2>/dev/null || true

# Open the first-run wizard as the user (not root).
sudo -u "$CONSOLE_USER" open "$APP" --args --first-run 2>/dev/null || true

exit 0

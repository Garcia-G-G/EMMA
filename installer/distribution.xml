<?xml version="1.0" encoding="utf-8"?>
<!--
  productbuild distribution: the installer GUI (Prompt 29, Part B2).
  Welcome → license → install to /Applications. No custom location (off by design).
-->
<installer-gui-script minSpecVersion="2">
    <title>Emma</title>
    <organization>com.garcia</organization>
    <welcome file="welcome.html" mime-type="text/html"/>
    <license file="license.txt" mime-type="text/plain"/>

    <!-- Apple Silicon + macOS 14+ only (matches the app's LSMinimumSystemVersion). -->
    <volume-check>
        <allowed-os-versions>
            <os-version min="14.0"/>
        </allowed-os-versions>
    </volume-check>

    <options customize="never" require-scripts="true" hostArchitectures="arm64"/>

    <choices-outline>
        <line choice="default">
            <line choice="com.garcia.emma"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="com.garcia.emma" visible="false">
        <pkg-ref id="com.garcia.emma"/>
    </choice>
    <pkg-ref id="com.garcia.emma" version="0" onConclusion="none">emma-component.pkg</pkg-ref>
</installer-gui-script>

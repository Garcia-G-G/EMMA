<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX manifest for Emma-Windows.msi (Prompt 30, Part C2). Per-user install to
  %LOCALAPPDATA%\Emma (no admin), Start-menu shortcut, Task Scheduler auto-start,
  uninstall via Programs and Features. Code signing (Part C3) is a separate
  signtool step on the built .msi — Garcia's EV cert (~$100/yr); see WINDOWS.md.

  Build (on Windows, after build_windows.py):
    heat dir dist\Emma-Windows -cg EmmaFiles -dr INSTALLDIR -srd -sreg -gg -out files.wxs
    candle wix-installer.xml files.wxs
    light -ext WixUIExtension wix-installer.wixobj files.wixobj -o dist\Emma-Windows.msi
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" Name="Emma" Language="1033" Version="1.0.0"
           Manufacturer="Garcia" UpgradeCode="6E2C1F7A-3B5D-4C9E-A1F2-EMMA00000001">
    <Package InstallScope="perUser" InstallerVersion="500" Compressed="yes"
             Description="Emma — asistente de voz" />
    <MajorUpgrade DowngradeErrorMessage="Ya hay una versión más nueva de Emma instalada." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Per-user: %LOCALAPPDATA%\Emma -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="LocalAppDataFolder">
        <Directory Id="INSTALLDIR" Name="Emma" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppShortcutFolder" Name="Emma" />
      </Directory>
    </Directory>

    <Feature Id="Main" Title="Emma" Level="1">
      <ComponentGroupRef Id="EmmaFiles" />   <!-- generated by heat from dist\Emma-Windows -->
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="AutoStartTask" />
    </Feature>

    <DirectoryRef Id="AppShortcutFolder">
      <Component Id="StartMenuShortcut" Guid="*">
        <Shortcut Id="EmmaStartMenu" Name="Emma"
                  Target="[INSTALLDIR]Emma.exe" WorkingDirectory="INSTALLDIR" />
        <RemoveFolder Id="RemoveAppShortcutFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\Garcia\Emma" Name="installed"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Auto-start at logon via Task Scheduler (Windows's launchd equivalent). -->
    <DirectoryRef Id="INSTALLDIR">
      <Component Id="AutoStartTask" Guid="*">
        <RegistryValue Root="HKCU" Key="Software\Microsoft\Windows\CurrentVersion\Run"
                       Name="Emma" Type="string" Value="[INSTALLDIR]Emma.exe" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <UIRef Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />
  </Product>
</Wix>
